# PodcastIndex API credentials — get yours free at https://api.podcastindex.org
PODCASTINDEX_API_KEY=your_api_key_here
PODCASTINDEX_API_SECRET=your_api_secret_here

# HuggingFace token — get yours at https://huggingface.co/settings/tokens
# Enables higher rate limits and faster model downloads
HF_TOKEN=your_hf_token_here

# Suppress HuggingFace symlinks warning (Windows doesn't support symlinks by default)
HF_HUB_DISABLE_SYMLINKS_WARNING=1

# Absolute path to the Transcriptions folder in your Obsidian vault
OBSIDIAN_TRANSCRIPTIONS_PATH=C:\DEV\Obsidian\Nelson\projects\SpotifyTranscript\Transcriptions

# Whisper model to use for transcription (default: medium.en)
# Options: tiny.en, base.en, small.en, medium.en, large-v2, large-v3
WHISPER_MODEL=medium.en

# LM Studio settings (optional — used for episode summary generation)
LMSTUDIO_URL=http://169.254.83.107:1234
LMSTUDIO_MODEL=qwen2.5-7b-instruct-1m
